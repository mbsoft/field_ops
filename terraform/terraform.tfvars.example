project_id = "my-gcp-project-id"
region     = "us-central1"

service_name = "field-ops"
image_tag    = "latest"

mongo_url = "mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority"
db_name   = "field_ops"

cors_origins = "*"

cloud_run_memory = "1Gi"
cloud_run_cpu    = "1"
min_instances    = 0
max_instances    = 3

allow_unauthenticated = true
